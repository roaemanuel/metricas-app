# ── MetricHub GA4 Sync — Variables de entorno ──────────────────────────────
# Copiar como .env y completar con valores reales
# NUNCA subir el .env a git (ya está en .gitignore)

# ID de la propiedad GA4 (solo números — lo encontrás en GA4 > Admin > Detalles de la propiedad)
GA4_PROPERTY_ID=123456789

# Cuenta de servicio de Google Cloud (del archivo JSON descargado)
GOOGLE_CLIENT_EMAIL=metricas-ga4@mi-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# Supabase (usar service_role key, NO la anon key — está en Supabase > Settings > API)
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
